{
  "manifest_version": 3,
  "name": "modify-plugin",
  "version": "0.0.1",
  "description": "modify-plugin description",
  "author": "modify",
  "action": {
    "default_icon": {
      "16": "plugin.png",
      "32": "plugin.png",
      "48": "plugin.png",
      "64": "plugin.png",
      "128": "plugin.png"
    },
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "16": "plugin.png",
    "32": "plugin.png",
    "48": "plugin.png",
    "64": "plugin.png",
    "128": "plugin.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab"
  ],
  "options_ui": {
    "page": "popup/options.html",
    "open_in_tab": true
  }
}
